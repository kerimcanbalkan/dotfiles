{
    "layer": "bottom",
        "position": "bottom",
        "height": 18,
        "spacing": 5,
        "modules-left": ["hyprland/workspaces", "hyprland/window"],
        "modules-right": ["hyprland/language","temperature","battery","pulseaudio","clock"],
        "hyprland/window": {
            "format": "{}"
        },
        "hyprland/workspaces" : {
            "disable-scroll": true,
            "all-outputs": true,
            "format": "{icon}",
            "format-icons": {
            "1": "I",
            "2": "II",
            "3": "III",
            "4": "IV",
            "5": "V",
            "6": "VI",
            }        },

            "temperature": {
            "critical-threshold": 90,
            "interval": 5,
            "format": "{icon} {temperatureC}°",
            "format-icons": [
                "",
            "",
            "",
            "",
            ""
            ],
            "tooltip": false
        },
        "hyprland/language": {
            "format": "   {}",
            "format-en": "us",
            "format-tr": "tr",
            "min-length": 5,
            "on-click": "hyprctl switchxkblayout all next",
            "tooltip": false
        },
        "battery": {
            "bat": "BAT0",
            "interval": 10,
            "states": {
                "warning": 30,
                "critical": 15
            },
            "format-time": "{H}:{M:02}",
            "format": "{icon}   {capacity}% ({time})",
            "format-charging": "   {capacity}% ({time})",
            "format-full": "{icon}   {capacity}%",
            "format-alt": "{icon}   {power}W",
            "format-plugged": "   {capacity}%",
            "format-icons": [
                "",
            "",
            "",
            "",
            ""
            ],
            "tooltip": false
        },
        "clock": {
            "format": "{:%d/%m/%Y %H:%M}",
            "tooltip-format": "<tt><small>{calendar}</small></tt>",
            "calendar": {
                "format": {
                    "months": "<span color='#ebdbb2'><b>{}</b></span>",
                    "today": "<span color='#98971a'><b>{}</b></span>"
                }
            }
        },
        "pulseaudio": {
            "format": "{icon}   {volume}%",
            "format-icons": {
                "default": ["\uf026", "\uf027", "\uf028"]
            },
            "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
            "on-click-right": "pavucontrol",
            "format-muted": "\uf00d {volume}%"
        },
}